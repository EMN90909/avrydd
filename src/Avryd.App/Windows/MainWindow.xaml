<Window x:Class="Avryd.App.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avryd Launcher"
        Width="900" Height="660"
        MinWidth="760" MinHeight="540"
        Background="{StaticResource PrimaryBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource PrimaryFont}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        AutomationProperties.Name="Avryd Screen Reader Launcher">

    <Window.Resources>
        <ResourceDictionary Source="../Styles/Theme.xaml"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource HighlightBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="AVRYD" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Screen Reader" Foreground="{StaticResource SubtextBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Status Card -->
                <Border DockPanel.Dock="Top" Margin="12,0,12,12" Padding="12,10"
                        Background="{StaticResource AccentBrush}" CornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Style="{StaticResource StatusDot}"
                                     Fill="{StaticResource SuccessBrush}"/>
                            <TextBlock x:Name="StatusLabel" Text="Active" FontSize="13"
                                       Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="ModeLabel" Text="Browse Mode" Foreground="{StaticResource SubtextBrush}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button x:Name="NavDashboard" Content="📊  Dashboard" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavDashboard_Click" AutomationProperties.Name="Dashboard"/>
                    <Button x:Name="NavSettings" Content="⚙  Settings" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavSettings_Click" AutomationProperties.Name="Settings"/>
                    <Button x:Name="NavPlugins" Content="🧩  Plugins" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavPlugins_Click" AutomationProperties.Name="Plugins"/>
                    <Button x:Name="NavLanguages" Content="🌐  Languages" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavLanguages_Click" AutomationProperties.Name="Languages"/>
                    <Button x:Name="NavShortcuts" Content="⌨  Shortcuts" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavShortcuts_Click" AutomationProperties.Name="Keyboard shortcuts"/>
                    <Button x:Name="NavProfile" Content="👤  Account" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavProfile_Click" AutomationProperties.Name="Account"/>
                    <Button x:Name="NavHelp" Content="❓  Help" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,12" Margin="0,2"
                            Click="NavHelp_Click" AutomationProperties.Name="Help"/>
                </StackPanel>

                <!-- Bottom Actions -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,12">
                    <Button x:Name="ToggleBtn" Content="⏸  Pause Avryd" Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left" Padding="16,10" Margin="0,2"
                            Click="ToggleBtn_Click" AutomationProperties.Name="Pause or resume Avryd"/>
                    <Button Content="✕  Quit Avryd" Style="{StaticResource DangerButton}"
                            HorizontalContentAlignment="Left" Padding="16,10" Margin="0,2"
                            Click="QuitBtn_Click" AutomationProperties.Name="Quit Avryd"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28">

                <!-- Dashboard Panel -->
                <StackPanel x:Name="PanelDashboard">
                    <TextBlock Text="Dashboard" Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="GreetingText" Style="{StaticResource BodyText}" Margin="0,0,0,24"/>

                    <!-- Stats Row -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,24">
                        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock x:Name="StatSessions" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource HighlightBrush}"/>
                                <TextBlock Text="Sessions" Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="4,0">
                            <StackPanel>
                                <TextBlock x:Name="StatTime" Text="0h 0m" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource HighlightBrush}"/>
                                <TextBlock Text="Usage Time" Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="StatPlugins" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource HighlightBrush}"/>
                                <TextBlock Text="Plugins" Style="{StaticResource BodyText}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Quick Actions -->
                    <TextBlock Text="QUICK ACTIONS" Style="{StaticResource FormLabel}" Margin="0,0,0,12"/>
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,24">
                        <Button Content="🔊 Read Current Item" Style="{StaticResource AvrydButton}"
                                Margin="0,0,8,0" Height="48" Click="ReadCurrentItem_Click"
                                AutomationProperties.Name="Read the currently focused item"/>
                        <Button Content="⏹ Stop Speaking" Style="{StaticResource SecondaryButton}"
                                Height="48" Click="StopSpeaking_Click"
                                AutomationProperties.Name="Stop all speech immediately"/>
                    </UniformGrid>

                    <!-- Voice Commands status -->
                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Voice Commands" Style="{StaticResource SubheadingText}" FontSize="16"/>
                                <TextBlock x:Name="VoiceCommandStatus" Style="{StaticResource BodyText}"
                                           Text="Disabled — enable in Settings"/>
                            </StackPanel>
                            <Button x:Name="VoiceToggleBtn" Content="Enable" DockPanel.Dock="Right"
                                    Style="{StaticResource AvrydButton}" VerticalAlignment="Center"
                                    Click="VoiceToggleBtn_Click" AutomationProperties.Name="Toggle voice commands"/>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Settings Panel -->
                <StackPanel x:Name="PanelSettings" Visibility="Collapsed">
                    <TextBlock Text="Settings" Style="{StaticResource HeadingText}" Margin="0,0,0,24"/>

                    <!-- Voice Section -->
                    <TextBlock Text="SPEECH" Style="{StaticResource FormLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Voice" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="VoiceCombo" Style="{StaticResource AvrydComboBox}"
                                      Height="44" Margin="0,0,0,16"
                                      AutomationProperties.Name="Select voice"
                                      SelectionChanged="VoiceCombo_SelectionChanged"/>

                            <TextBlock Text="Speech Rate" Style="{StaticResource FormLabel}"/>
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock x:Name="RateDisplay" DockPanel.Dock="Right"
                                           Text="175 wpm" Foreground="{StaticResource HighlightBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Width="60"/>
                                <Slider x:Name="RateSlider" Style="{StaticResource AvrydSlider}"
                                        Minimum="80" Maximum="400" Value="175"
                                        AutomationProperties.Name="Speech rate in words per minute"
                                        ValueChanged="RateSlider_ValueChanged"/>
                            </DockPanel>

                            <TextBlock Text="Volume" Style="{StaticResource FormLabel}"/>
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock x:Name="VolumeDisplay" DockPanel.Dock="Right"
                                           Text="100%" Foreground="{StaticResource HighlightBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Width="60"/>
                                <Slider x:Name="VolumeSlider" Style="{StaticResource AvrydSlider}"
                                        Minimum="0" Maximum="1" Value="1"
                                        AutomationProperties.Name="Speech volume"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </DockPanel>

                            <TextBlock Text="Verbosity" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="VerbosityCombo" Style="{StaticResource AvrydComboBox}"
                                      Height="44" Margin="0,0,0,16"
                                      AutomationProperties.Name="Select verbosity level">
                                <ComboBoxItem Content="Minimal" Tag="minimal"/>
                                <ComboBoxItem Content="Standard" Tag="standard" IsSelected="True"/>
                                <ComboBoxItem Content="Verbose" Tag="verbose"/>
                            </ComboBox>

                            <TextBlock Text="Punctuation" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="PunctuationCombo" Style="{StaticResource AvrydComboBox}"
                                      Height="44"
                                      AutomationProperties.Name="Select punctuation level">
                                <ComboBoxItem Content="None" Tag="none"/>
                                <ComboBoxItem Content="Some" Tag="some" IsSelected="True"/>
                                <ComboBoxItem Content="All" Tag="all"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Behavior Section -->
                    <TextBlock Text="BEHAVIOR" Style="{StaticResource FormLabel}" Margin="0,16,0,0"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="ChkStartup" Style="{StaticResource AvrydCheckBox}"
                                      Content="Launch Avryd at Windows startup"
                                      AutomationProperties.Name="Launch Avryd at Windows startup"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkMinimize" Style="{StaticResource AvrydCheckBox}"
                                      Content="Minimize to tray instead of closing"
                                      AutomationProperties.Name="Minimize to system tray when closed"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkNotifications" Style="{StaticResource AvrydCheckBox}"
                                      Content="Announce notifications"
                                      AutomationProperties.Name="Read system notifications aloud"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkTooltips" Style="{StaticResource AvrydCheckBox}"
                                      Content="Speak tooltips and hints"
                                      AutomationProperties.Name="Speak tooltips and help text"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkOcr" Style="{StaticResource AvrydCheckBox}"
                                      Content="Enable OCR fallback for inaccessible apps"
                                      AutomationProperties.Name="Use optical character recognition for apps without accessibility"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkBraille" Style="{StaticResource AvrydCheckBox}"
                                      Content="Enable Braille keyboard support"
                                      AutomationProperties.Name="Enable Braille keyboard input"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="ChkFocusHighlight" Style="{StaticResource AvrydCheckBox}"
                                      Content="Show visual focus highlight"
                                      AutomationProperties.Name="Show visual highlight on focused element"
                                      Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Profile Section -->
                    <TextBlock Text="PROFILES" Style="{StaticResource FormLabel}" Margin="0,16,0,0"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <UniformGrid Rows="1" Columns="4">
                                <Button Content="Standard" Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,4,0" Click="ProfileBtn_Click" Tag="standard"/>
                                <Button Content="Fast" Style="{StaticResource SecondaryButton}"
                                        Margin="4,0" Click="ProfileBtn_Click" Tag="fast"/>
                                <Button Content="New User" Style="{StaticResource SecondaryButton}"
                                        Margin="4,0" Click="ProfileBtn_Click" Tag="new_user"/>
                                <Button Content="Quiet" Style="{StaticResource SecondaryButton}"
                                        Margin="4,0,0,0" Click="ProfileBtn_Click" Tag="quiet"/>
                            </UniformGrid>
                            <Separator/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Settings" Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0" Click="ExportSettings_Click"/>
                                <Button Content="Import Settings" Style="{StaticResource SecondaryButton}"
                                        Click="ImportSettings_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Plugins Panel -->
                <StackPanel x:Name="PanelPlugins" Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,24">
                        <TextBlock Text="Plugins" Style="{StaticResource HeadingText}" DockPanel.Dock="Left"/>
                        <Button Content="🔄 Refresh" Style="{StaticResource SecondaryButton}"
                                DockPanel.Dock="Right" Click="RefreshPlugins_Click"
                                AutomationProperties.Name="Refresh available plugins from GitHub"/>
                    </DockPanel>

                    <TextBlock Text="INSTALLED PLUGINS" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="InstalledPluginsList" Margin="0,0,0,24">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}">
                                    <DockPanel>
                                        <Button Content="Remove" DockPanel.Dock="Right"
                                                Style="{StaticResource DangerButton}" VerticalAlignment="Center"
                                                Tag="{Binding Id}" Click="RemovePlugin_Click"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource SubheadingText}" FontSize="15"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}"/>
                                            <TextBlock Text="{Binding Version}" Style="{StaticResource BodyText}" FontSize="11"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="AVAILABLE FROM GITHUB" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="AvailablePluginsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}">
                                    <DockPanel>
                                        <Button Content="Install" DockPanel.Dock="Right"
                                                Style="{StaticResource AvrydButton}" VerticalAlignment="Center"
                                                Tag="{Binding}" Click="InstallPlugin_Click"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource SubheadingText}" FontSize="15"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Languages Panel -->
                <StackPanel x:Name="PanelLanguages" Visibility="Collapsed">
                    <TextBlock Text="Languages" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,24">
                        Install language packs to enable Piper TTS voices in different languages.
                        Place .onnx voice model files into the resources\piper\voices folder.
                    </TextBlock>

                    <TextBlock Text="AVAILABLE VOICES" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="VoicesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}">
                                    <DockPanel>
                                        <Button Content="Use" DockPanel.Dock="Right"
                                                Style="{StaticResource AvrydButton}" VerticalAlignment="Center"
                                                Tag="{Binding}" Click="UseVoice_Click"/>
                                        <TextBlock Text="{Binding}" Style="{StaticResource SubheadingText}" FontSize="14"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Shortcuts Panel -->
                <StackPanel x:Name="PanelShortcuts" Visibility="Collapsed">
                    <TextBlock Text="Keyboard Shortcuts" Style="{StaticResource HeadingText}" Margin="0,0,0,24"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="NAVIGATION" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>
                            <ItemsControl>
                                <ItemsControl.Items>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+Right" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Next item" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+Left" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Previous item" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+Home" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Jump to top" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+End" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Jump to bottom" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+M" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Toggle reading mode" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+A" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Read all content" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+S" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Stop speaking" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+P" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Repeat last item" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+B" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Jump to next button" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+L" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Jump to next link" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+E" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Jump to next edit field" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Ctrl+Alt+G" FontWeight="Bold" Width="180"
                                                   Foreground="{StaticResource HighlightBrush}"/>
                                        <TextBlock Text="Open Avryd launcher" Style="{StaticResource BodyText}"/>
                                    </StackPanel>
                                </ItemsControl.Items>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Account Panel -->
                <StackPanel x:Name="PanelProfile" Visibility="Collapsed">
                    <TextBlock Text="Account" Style="{StaticResource HeadingText}" Margin="0,0,0,24"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock x:Name="AccountEmail" Style="{StaticResource SubheadingText}" FontSize="16"/>
                            <TextBlock x:Name="AccountStatus" Style="{StaticResource BodyText}" Margin="0,4,0,16"/>
                            <TextBlock x:Name="AccountStats" Style="{StaticResource BodyText}"/>
                            <Separator/>
                            <Button Content="Sign Out" Style="{StaticResource DangerButton}"
                                    Width="140" HorizontalAlignment="Left" Click="SignOut_Click"
                                    AutomationProperties.Name="Sign out of Avryd"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Help Panel -->
                <StackPanel x:Name="PanelHelp" Visibility="Collapsed">
                    <TextBlock Text="Help &amp; Support" Style="{StaticResource HeadingText}" Margin="0,0,0,24"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Getting Started" Style="{StaticResource SubheadingText}" FontSize="16" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource BodyText}">
                                Avryd runs silently in the background and reads your screen automatically.
                                Use the keyboard shortcuts to navigate. Open the launcher anytime with Ctrl+Alt+G.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Voice Commands" Style="{StaticResource SubheadingText}" FontSize="16" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource BodyText}">
                                Say "Open Chrome", "Stop speaking", "Volume up", "Next item", "Previous item" and more.
                                Enable voice commands in Settings.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Troubleshooting" Style="{StaticResource SubheadingText}" FontSize="16" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource BodyText}">
                                If speech stops, press Ctrl+Alt+S then try again. Make sure Piper TTS voice files
                                are in resources\piper\voices. Run as Administrator for full access to all apps.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
