<Window x:Class="Avryd.App.Windows.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avryd — Getting Started"
        Width="680" Height="600"
        MinWidth="560" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        AutomationProperties.Name="Avryd Onboarding Window">

    <Window.Resources>
        <ResourceDictionary Source="../Styles/Theme.xaml"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="16,16,0,0" Padding="24,16"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AVRYD — Setup" Style="{StaticResource SubheadingText}" FontSize="18"/>
                    <TextBlock x:Name="StepIndicator" Style="{StaticResource BodyText}"
                               VerticalAlignment="Bottom" Margin="16,0,0,1"
                               AutomationProperties.LiveSetting="Polite"/>
                </StackPanel>
            </Border>

            <!-- Steps Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,24">
                <StackPanel>
                    <!-- Step: Voice Setup -->
                    <StackPanel x:Name="StepVoice" Visibility="Visible">
                        <TextBlock Text="Choose Your Voice" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,24">
                            Avryd uses Piper TTS to speak. Select a voice below.
                            Make sure the voice files are in the resources\piper\voices folder.
                        </TextBlock>

                        <TextBlock Text="VOICE" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="VoiceCombo" Style="{StaticResource AvrydComboBox}"
                                  Height="44" Margin="0,0,0,16"
                                  AutomationProperties.Name="Select voice"
                                  SelectionChanged="VoiceCombo_SelectionChanged"/>

                        <TextBlock Text="SPEECH RATE" Style="{StaticResource FormLabel}"/>
                        <Slider x:Name="RateSlider" Style="{StaticResource AvrydSlider}"
                                Minimum="80" Maximum="400" Value="175" Margin="0,0,0,4"
                                AutomationProperties.Name="Speech rate"
                                ValueChanged="RateSlider_ValueChanged"/>
                        <TextBlock x:Name="RateLabel" Style="{StaticResource BodyText}"
                                   Text="175 words per minute" Margin="0,0,0,16"/>

                        <Button Content="🔊 Test Voice" Style="{StaticResource SecondaryButton}"
                                Width="160" HorizontalAlignment="Left" Click="TestVoice_Click"
                                AutomationProperties.Name="Test the selected voice"/>
                    </StackPanel>

                    <!-- Step: Shortcuts -->
                    <StackPanel x:Name="StepShortcuts" Visibility="Collapsed">
                        <TextBlock Text="Essential Shortcuts" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,24">
                            Here are the key shortcuts to get you started with Avryd:
                        </TextBlock>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + S" FontWeight="Bold"
                                               Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Stop speaking" Style="{StaticResource BodyText}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + Right" FontWeight="Bold" Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Next item" Style="{StaticResource BodyText}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + Left" FontWeight="Bold" Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Previous item" Style="{StaticResource BodyText}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + M" FontWeight="Bold" Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Toggle reading mode" Style="{StaticResource BodyText}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + G" FontWeight="Bold" Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Open Avryd launcher" Style="{StaticResource BodyText}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Ctrl + Alt + A" FontWeight="Bold" Foreground="{StaticResource HighlightBrush}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="Read all content" Style="{StaticResource BodyText}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Step: Profile -->
                    <StackPanel x:Name="StepProfile" Visibility="Collapsed">
                        <TextBlock Text="Choose a Profile" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,24">
                            Select a starting profile. You can change any setting at any time.
                        </TextBlock>

                        <RadioButton x:Name="ProfileStandard" Content="Standard — Balanced for most users"
                                     IsChecked="True" Foreground="{StaticResource TextBrush}"
                                     FontSize="14" Margin="0,0,0,12"/>
                        <RadioButton x:Name="ProfileFast" Content="Fast Reader — High speed, minimal verbosity"
                                     Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,0,0,12"/>
                        <RadioButton x:Name="ProfileNewUser" Content="New User — Detailed descriptions and hints"
                                     Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,0,0,12"/>
                        <RadioButton x:Name="ProfileQuiet" Content="Quiet Mode — Reduced chatter and notifications"
                                     Foreground="{StaticResource TextBrush}" FontSize="14" Margin="0,0,0,12"/>
                    </StackPanel>

                    <!-- Step: Done -->
                    <StackPanel x:Name="StepDone" Visibility="Collapsed">
                        <TextBlock Text="You're all set!" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,24">
                            Avryd is ready to help you navigate your computer by sound.
                            It will run in the background. Use Ctrl+Alt+G to open this launcher anytime.
                        </TextBlock>
                        <Border Style="{StaticResource Card}" Background="#1A3A1A">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Fill="{StaticResource SuccessBrush}" Width="16" Height="16" Margin="0,0,12,0"/>
                                <TextBlock Text="Avryd is active and ready" Foreground="{StaticResource SuccessBrush}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Navigation Footer -->
            <Border Grid.Row="2" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="0,0,16,16" Padding="24,16">
                <DockPanel>
                    <Button x:Name="SkipBtn" Content="Skip Setup" DockPanel.Dock="Left"
                            Style="{StaticResource SecondaryButton}" Click="SkipBtn_Click"
                            AutomationProperties.Name="Skip setup and launch Avryd"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BackBtn" Content="← Back" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,12,0" IsEnabled="False" Click="BackBtn_Click"
                                AutomationProperties.Name="Go back to previous step"/>
                        <Button x:Name="NextBtn" Content="Next →" Style="{StaticResource AvrydButton}"
                                Click="NextBtn_Click"
                                AutomationProperties.Name="Continue to next step"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
